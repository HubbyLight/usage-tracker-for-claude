{
  "name": "claude-usage-tracker",
  "version": "0.1.0",
  "description": "Tray / menu-bar app that tracks your Claude.ai 5-hour and weekly usage at a glance",
  "main": "main.js",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "sync-install": "node scripts/sync-install.js"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.claudeusage.tracker",
    "productName": "Claude Usage",
    "win": {
      "target": "portable",
      "icon": "icon-256.png"
    },
    "mac": {
      "target": ["dmg", "zip"],
      "icon": "icon-512.png",
      "category": "public.app-category.utilities"
    }
  }
}
